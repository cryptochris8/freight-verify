# ==============================================================================
# FreightVerify - Environment Variables
# ==============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, add these in the Vercel dashboard under:
#   Project Settings > Environment Variables
# ==============================================================================


# ==============================================================================
# APP CONFIGURATION
# ==============================================================================

# The public-facing URL of the application (no trailing slash)
# Local: http://localhost:3000 | Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment: development | preview | production
NODE_ENV=development


# ==============================================================================
# CLERK - Authentication & Multi-Tenant Organizations
# ==============================================================================
# Get these from: https://dashboard.clerk.com → Your App → API Keys

# Publishable key (safe for client-side, starts with pk_test_ or pk_live_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key (server-side only, starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (must match routes in your Next.js app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# Clerk after-auth redirect (where users land after signing in)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Webhook secret for Clerk → your app user sync events
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ==============================================================================
# SUPABASE - Database (Postgres) & Storage
# ==============================================================================
# Note: Supabase is used for database and file storage ONLY.
# Authentication is handled entirely by Clerk.
#
# Get these from: https://supabase.com/dashboard → Project Settings → API

# Direct Postgres connection string (used by Drizzle ORM for migrations and queries)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# For connection pooling (recommended in production), use port 6543 with PgBouncer:
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.[project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase project URL (used for Storage API calls)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon/public key (safe for client-side, used for Storage uploads with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Supabase service role key (server-side only, bypasses RLS - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ==============================================================================
# STRIPE - Billing & Subscriptions
# ==============================================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable key (client-side, starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key (server-side only, starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret for Stripe → your app events
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# For local dev, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs for subscription tiers
# Create these in: Stripe Dashboard → Products → Add Product → Add Price (recurring/monthly)
# Starter Plan - $149/month
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Professional Plan - $399/month
STRIPE_PROFESSIONAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Business Plan - $799/month
STRIPE_BUSINESS_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ==============================================================================
# RESEND - Transactional Email (Daily Digests)
# ==============================================================================
# Get these from: https://resend.com/api-keys

# API key (starts with re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender email address (must be from a verified domain in Resend)
# Example: notifications@freightverify.com or noreply@freightverify.com
EMAIL_FROM=FreightVerify <notifications@freightverify.com>


# ==============================================================================
# TWILIO - SMS (OTP Delivery)
# ==============================================================================
# Get these from: https://console.twilio.com → Account Info

# Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio phone number for sending SMS (E.164 format)
# Purchase from: Twilio Console → Phone Numbers → Buy a Number
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX


# ==============================================================================
# FMCSA SAFER API - Carrier Verification
# ==============================================================================
# Register for a free API key at: https://mobile.fmcsa.dot.gov/developer/home
# Used to verify motor carrier authority, safety ratings, and insurance status

FMCSA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ==============================================================================
# SENTRY - Error Monitoring & Performance
# ==============================================================================
# Get these from: https://sentry.io → Project Settings → Client Keys (DSN)

# Data Source Name - used by both client and server to report errors
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000

# Auth token for source map uploads during build (Organization Auth Token)
# Create at: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
